# API Keys (obligatorias para herramientas de IA)
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=
# vacío = 2.5-pro → 1.5-pro → 2.5-flash → 1.5-flash
GEMINI_MODEL=

SERP_API_KEY=

# Poner en false para no usar Perplexity ni SerpAPI aunque exista la key (solo OpenAI + Gemini)
ENABLE_PERPLEXITY=true
ENABLE_SERP=true

# MySQL (Railway ofrece MySQL como add-on)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=cleexs_tools
MYSQL_USER=root
MYSQL_PASSWORD=

# Opcional: notificaciones
WEBHOOK_URL=
